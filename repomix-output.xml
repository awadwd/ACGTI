<file path="src/style.css">
/* ============================================
   16Personalities-Style Design System
   ============================================ */

:root {
  /* 16Personalities exact color scheme */
  --bg: #ffffff;
  --bg-soft: #f4f4f4;
  --bg-dark: #2c2c2c;
  --panel: #ffffff;
  --panel-strong: #e8e8e8;
  --border: #d0d0d0;
  --border-light: #e0e0e0;
  --text: #333333;
  --text-muted: #666666;
  --text-light: #999999;

  /* 16Personalities brand colors */
  --primary: #33a474;
  --primary-hover: #2d9168;
  --secondary: #88619a;
  --accent-blue: #4298b4;
  --accent-green: #33a474;
  --accent-purple: #88619a;
  --accent-orange: #e67e22;
  --accent-red: #e74c3c;
  --accent-yellow: #f1c40f;

  /* Trait colors - exact 16P colors */
  --trait-energy: #9b59b6;
  --trait-mind: #3498db;
  --trait-nature: #e74c3c;
  --trait-tactics: #f39c12;

  --success: #33a474;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);
  --radius-xl: 16px;
  --radius-lg: 12px;
  --radius-md: 8px;
  --radius-sm: 4px;
  --max-width: 1080px;
  --content-width: 720px;
  --body-font: "Open Sans", "Helvetica Neue", Helvetica, Arial, "Noto Sans SC", sans-serif;
  --display-font: "Montserrat", "Open Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
}

/* ============================================
   Base Styles
   ============================================ */

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  font-family: var(--body-font);
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
textarea,
select {
  font: inherit;
}

#app {
  min-height: 100vh;
}

/* ============================================
   Site Shell & Layout
   ============================================ */

.site-shell {
  position: relative;
  width: 100%;
  max-width: var(--max-width);
  margin: 0 auto;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Quiz page overrides for full-screen experience */
.site-shell:has(.quiz-page) {
  max-width: 100%;
}

.quiz-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: var(--bg);
}

/* ============================================
   Header & Navigation (16P Style)
   ============================================ */

.site-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 24px;
  background: var(--bg-soft);
  border-bottom: 1px solid var(--border);
